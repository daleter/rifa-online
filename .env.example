# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados PostgreSQL (Supabase)
# Pegue em: Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[senha]@[host]:5432/postgres

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SuaSenhaSeguraAqui123!

# Sessão (gere uma string aleatória de 64 chars)
SESSION_SECRET=troque_por_string_aleatoria_longa_aqui

# Telegram Bot
TELEGRAM_BOT_TOKEN=seu_token_do_botfather
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# Sorteio
SORTEIO_DATA_HORA=2025-07-15T20:00:00

# Pix (use nome SEM acentos — o código já remove, mas é mais seguro)
PIX_CHAVE=seu@email.com
PIX_NOME=Seu Nome Completo Sem Acento
PIX_CIDADE=SuaCidade

# Rifa
TOTAL_NUMEROS=120
PRECO_NUMERO=15
MINUTOS_EXPIRACAO_RESERVA=30
