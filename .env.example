# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados PostgreSQL (Supabase)
# Pegue em: Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.[SEU_PROJETO].supabase.co:5432/postgres

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=[SUA_SENHA_ADMIN]

# Sessão (gere uma string aleatória de 64 chars)
SESSION_SECRET=[STRING_ALEATORIA_LONGA]

# Telegram Bot
TELEGRAM_BOT_TOKEN=[SEU_TOKEN_DO_BOTFATHER]
TELEGRAM_CHAT_ID=[SEU_CHAT_ID]

# Sorteio
SORTEIO_DATA_HORA=2025-07-15T20:00:00

# Pix (use nome SEM acentos)
PIX_CHAVE=[SUA_CHAVE_PIX]
PIX_NOME=[SEU_NOME_SEM_ACENTO]
PIX_CIDADE=[SUA_CIDADE]

# Rifa
TOTAL_NUMEROS=120
PRECO_NUMERO=15
MINUTOS_EXPIRACAO_RESERVA=30
